{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "noEmit": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "baseUrl": "..",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "./**/*.ts",
    "../lib/**/*.ts",
    "../services/**/*.ts",
    "../tools/**/*.ts",
    "../types/**/*.ts"
  ],
  "exclude": [
    "../node_modules",
    "../app",
    "../components",
    "../lib/hooks"
  ]
}
